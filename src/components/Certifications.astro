---
import { content } from '../content';
import { L, t, type Lang } from '../i18n';
import Education from './Education.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<section class="sec wrap" id="certs">
  <div class="sec-eyebrow">$ ls ./certificates</div>
  <h2 class="sec-title">{t('certs', lang)}</h2>
  <div class="certs-grid">
    {content.certs.map((c) => (
      <div class="cert">
        <div class="badge-wrap">
          {!c.badgeImage.includes('/certificates/') && <div class="badge-glow"></div>}
          {c.badgeImage ? (
            <div class="badge-slot">
              <img class="badge-img" src={c.badgeImage} alt={`${L(c.name, lang)} — badge`} width="220" height="220" loading="lazy" decoding="async" />
            </div>
          ) : (
            <div class="badge-slot badge-fallback"><span>{c.issuer}</span></div>
          )}
        </div>
        <div style="display:flex;flex-direction:column;gap:6px">
          <h3>{L(c.name, lang)}</h3>
          <div class="meta">{c.issuer} · {c.year}</div>
          {c.credly && <a href={c.url} target="_blank" rel="noopener">{t('viewCred', lang)} ↗</a>}
        </div>
      </div>
    ))}
  </div>
  <Education lang={lang} />
</section>
