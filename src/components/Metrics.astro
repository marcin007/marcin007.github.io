---
import { content } from '../content';
import { L, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<div class="metrics wrap">
  {content.metrics.map((m) => (
    <div class="metric">
      <div class="val">{m.value}</div>
      <div class="lbl">{L(m.label, lang)}</div>
    </div>
  ))}
</div>
